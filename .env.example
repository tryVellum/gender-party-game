# Секретный ключ Flask. Для публичного репозитория не используйте это значение в реальной игре.
SECRET_KEY=replace-with-a-long-random-string

# Секретная часть адреса администратора без начального и конечного слеша.
# Пример адреса: http://127.0.0.1:5000/my-private-admin-page
ADMIN_SECRET_PATH=my-private-admin-page

# Пол ребёнка для финального раскрытия: boy или girl.
ACTUAL_GENDER=boy

# Сервер слушает все сетевые интерфейсы, чтобы телефоны в одной Wi-Fi сети могли подключиться.
HOST=0.0.0.0
PORT=5000

# Для обычной игры оставьте 0. Значение 1 включает режим отладки.
DEBUG=0
